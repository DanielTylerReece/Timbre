<?xml version="1.0" encoding="UTF-8"?>
<schemalist gettext-domain="timbre">
  <schema id="io.github.tylerreece.timbre" path="/io/github/tylerreece/timbre/">

    <!-- Window geometry -->
    <key name="window-width" type="i">
      <default>1000</default>
    </key>
    <key name="window-height" type="i">
      <default>800</default>
    </key>

    <!-- Playback state persistence -->
    <key name="last-volume" type="i">
      <default>10</default>
    </key>
    <key name="repeat" type="i">
      <default>0</default>
    </key>

    <!-- Audio sink -->
    <key name="preferred-sink" type="i">
      <range min="0" max="6"/>
      <default>0</default>
    </key>
    <key name="alsa-device" type="s">
      <default>'default'</default>
    </key>

    <!-- Audio quality — renamed from "quality" (tidal-specific) -->
    <!-- 0 = unlimited, positive integer = max kbps cap -->
    <key name="max-bitrate" type="i">
      <default>0</default>
    </key>

    <!-- Audio processing -->
    <key name="normalize" type="b">
      <default>false</default>
    </key>
    <key name="quadratic-volume" type="b">
      <default>false</default>
    </key>

    <!-- Background play (renamed from run-background) -->
    <key name="background-play" type="b">
      <default>true</default>
    </key>

    <!-- Fetch lyrics from LRCLIB when Jellyfin has none -->
    <key name="external-lyrics" type="b">
      <default>true</default>
    </key>

    <!-- Jellyfin server connection -->
    <key name="server-url" type="s">
      <default>''</default>
    </key>
    <key name="device-id" type="s">
      <default>''</default>
    </key>

    <!-- AI features (Phase 2+) -->
    <key name="ai-provider" type="s">
      <default>'none'</default>
    </key>
    <key name="ai-endpoint" type="s">
      <default>''</default>
    </key>
    <key name="ai-model" type="s">
      <default>''</default>
    </key>

    <!-- Push AI-generated bios up to Jellyfin (Overview) so other apps see them -->
    <key name="push-bios" type="b">
      <default>false</default>
    </key>

    <!-- Library selection -->
    <key name="selected-libraries" type="as">
      <default>[]</default>
    </key>

    <!-- Image disk-cache size limit (MiB). utils.evict_image_cache reads this
         (with a fallback when the key is absent) to bound the on-disk image
         cache via an LRU sweep. -->
    <key name="cache-size-mb" type="i">
      <range min="64" max="8192"/>
      <default>512</default>
      <summary>Image cache size limit (MiB)</summary>
      <description>Maximum size of the on-disk image cache in mebibytes. When the cache exceeds this limit the least-recently-used images are evicted.</description>
    </key>

    <!-- Discord Rich Presence: publish now-playing to a running Discord client
         via its local IPC socket. Fail-silent when Discord is not present. -->
    <key name="discord-rpc" type="b">
      <default>false</default>
      <summary>Discord Rich Presence</summary>
      <description>Show the currently playing track in your Discord status via the local Discord client. Requires Discord to be running on the same machine; has no effect otherwise.</description>
    </key>

  </schema>
</schemalist>
